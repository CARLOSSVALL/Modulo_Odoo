<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         VISTAS: lost.object.category
         ================================================================ -->

    <!-- Vista Lista -->
    <record id="view_lost_object_category_tree" model="ir.ui.view">
        <field name="name">lost.object.category.tree</field>
        <field name="model">lost.object.category</field>
        <field name="arch" type="xml">
            <tree string="Categorías" editable="bottom">
                <field name="name"/>
                <field name="object_count" string="Nº Objetos"/>
                <field name="active" widget="toggle_button"/>
            </tree>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_lost_object_category_form" model="ir.ui.view">
        <field name="name">lost.object.category.form</field>
        <field name="model">lost.object.category</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre de la categoría"/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="toggle_button"/>
                        <field name="object_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Objetos en esta Categoría">
                            <field name="lost_object_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="registration_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_lost_object_category" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">lost.object.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">¡Sin categorías todavía!</p>
            <p>Crea categorías como "Electrónica", "Ropa", "Papelería", etc.</p>
        </field>
    </record>

</odoo>
