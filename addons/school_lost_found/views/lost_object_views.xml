<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         VISTAS: lost.object  (Kanban + Tree + Form + Búsqueda)
         ================================================================ -->

    <!-- Vista KANBAN -->
    <record id="view_lost_object_kanban" model="ir.ui.view">
        <field name="name">lost.object.kanban</field>
        <field name="model">lost.object</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="photo"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="registration_date"/>
                <field name="student_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click o_kanban_record_has_image_fill
                                            #{record.state.raw_value == 'lost' ? 'border-danger' : 'border-success'}"
                             style="min-height:220px; overflow:hidden;">
                            <!-- Foto del objeto -->
                            <div class="o_kanban_image_fill_left d-none d-md-block"
                                 t-attf-style="background-image: url(#{kanban_image('lost.object', 'photo', record.id.raw_value)}); background-size:cover; min-height:120px;">
                            </div>
                            <div class="oe_kanban_details p-2">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted small">
                                    <field name="category_id"/>
                                </div>
                                <div class="mt-1">
                                    <span t-if="record.state.raw_value == 'lost'"
                                          class="badge text-bg-danger">🔴 Perdido</span>
                                    <span t-if="record.state.raw_value == 'delivered'"
                                          class="badge text-bg-success">✅ Entregado</span>
                                </div>
                                <div class="text-muted small mt-1">
                                    <field name="registration_date"/>
                                </div>
                                <t t-if="record.student_id.raw_value">
                                    <div class="text-muted small">
                                        👤 <field name="student_id"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista LISTA (Tree) -->
    <record id="view_lost_object_tree" model="ir.ui.view">
        <field name="name">lost.object.tree</field>
        <field name="model">lost.object</field>
        <field name="arch" type="xml">
            <tree string="Objetos Perdidos"
                  decoration-danger="state == 'lost'"
                  decoration-success="state == 'delivered'">
                <field name="photo" widget="image" options="{'size': [48, 48]}"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="registration_date"/>
                <field name="state"
                       decoration-danger="state == 'lost'"
                       decoration-success="state == 'delivered'"
                       widget="badge"/>
                <field name="student_id"/>
            </tree>
        </field>
    </record>

    <!-- Vista FORMULARIO -->
    <record id="view_lost_object_form" model="ir.ui.view">
        <field name="name">lost.object.form</field>
        <field name="model">lost.object</field>
        <field name="arch" type="xml">
            <form string="Objeto Perdido">
                <header>
                    <button name="action_publish"
                            string="📢 Publicar"
                            type="object"
                            class="btn-success"/>
                    <!-- Botón visible únicamente cuando el estado es 'lost' -->
                    <button name="action_open_deliver_wizard"
                            string="✋ Entregar Objeto"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'lost'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="lost,delivered"/>
                </header>
                <sheet>
                    <!-- Imagen del objeto -->
                    <field name="photo"
                           widget="image"
                           class="oe_avatar"
                           options="{'placeholder': '/web/static/img/placeholder.png'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre del objeto (ej: Auriculares negros)"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información del Objeto">
                            <field name="category_id"
                                   options="{'no_create_edit': False}"/>
                            <field name="registration_date"/>
                        </group>
                        <group string="Estado y Entrega">
                            <field name="state" readonly="1"/>
                            <field name="student_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="description" placeholder="Añade una descripción detallada del objeto..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista BÚSQUEDA -->
    <record id="view_lost_object_search" model="ir.ui.view">
        <field name="name">lost.object.search</field>
        <field name="model">lost.object</field>
        <field name="arch" type="xml">
            <search string="Buscar Objetos Perdidos">
                <field name="name" string="Nombre"/>
                <field name="category_id" string="Categoría"/>
                <field name="student_id" string="Alumno"/>
                <separator/>
                <filter name="filter_lost" string="🔴 Perdidos"
                        domain="[('state', '=', 'lost')]"/>
                <filter name="filter_delivered" string="✅ Entregados"
                        domain="[('state', '=', 'delivered')]"/>
                <separator/>
                <filter name="filter_today" string="Registrados Hoy"
                        domain="[('registration_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_category" string="Categoría"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_date" string="Fecha"
                            context="{'group_by': 'registration_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de ventana principal -->
    <record id="action_lost_object" model="ir.actions.act_window">
        <field name="name">Objetos Perdidos</field>
        <field name="res_model">lost.object</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_filter_lost': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡No hay objetos perdidos registrados!
            </p>
            <p>Cuando encuentres un objeto, regístralo aquí para que su dueño pueda reclamarlo.</p>
        </field>
    </record>

</odoo>
