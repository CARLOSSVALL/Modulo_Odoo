<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         VISTAS: school.student
         ================================================================ -->

    <!-- Vista Lista (Tree) -->
    <record id="view_school_student_tree" model="ir.ui.view">
        <field name="name">school.student.tree</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <tree string="Alumnos" decoration-muted="lost_object_count == 0">
                <field name="name"/>
                <field name="nia"/>
                <field name="lost_object_count" string="Objetos Recogidos"/>
            </tree>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_school_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form string="Alumno">
                <header>
                    <button name="action_save_student" string="Agregar Alumno" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" force_save="1" placeholder="Nombre Automático..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del Alumno">
                            <field name="first_name" placeholder="Ej: Juan"/>
                            <field name="last_name" placeholder="Ej: Pérez García"/>
                            <field name="nia" placeholder="Ej: 12345"/>
                            <field name="lost_object_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Objetos Entregados" name="objects">
                            <field name="lost_object_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="registration_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Búsqueda -->
    <record id="view_school_student_search" model="ir.ui.view">
        <field name="name">school.student.search</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search string="Buscar Alumnos">
                <field name="name" string="Nombre"/>
                <field name="nia" string="NIA"/>
                <separator/>
                <filter name="with_objects" string="Con Objetos" domain="[('lost_object_count', '>', 0)]"/>
            </search>
        </field>
    </record>

    <!-- Acción de ventana -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Alumnos</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Aún no hay alumnos registrados!
            </p>
            <p>Añade los alumnos del centro para poder gestionar la entrega de objetos.</p>
        </field>
    </record>

</odoo>
